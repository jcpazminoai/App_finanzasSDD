generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  CASH
  BANK
  CREDIT_CARD
  WALLET
  INVESTMENT
  OTHER
}

enum CategoryKind {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum BudgetPeriod {
  MONTH
  WEEK
  YEAR
}

enum SavingGoalStatus {
  ACTIVE
  PAUSED
  ACHIEVED
  CANCELLED
}

enum NotificationType {
  BUDGET
  GOAL
  REMINDER
  SYSTEM
}

model User {
  id              String        @id @default(uuid())
  name            String
  email           String        @unique
  passwordHash    String        @map("password_hash")
  currency        String        @default("COP")
  locale          String        @default("es-CO")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  sessions        UserSession[]
  accounts        Account[]
  categories      Category[]
  transactions    Transaction[]
  budgets         Budget[]
  savingGoals     SavingGoal[]
  contributions   SavingGoalContribution[]
  notifications   Notification[]

  @@map("users")
}

model UserSession {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  refreshToken String    @unique @map("refresh_token")
  userAgent    String?   @map("user_agent")
  ipAddress    String?   @map("ip_address")
  createdAt    DateTime  @default(now()) @map("created_at")
  revokedAt    DateTime? @map("revoked_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_sessions")
}

model Account {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  name              String
  type              AccountType
  currency          String
  balance           Decimal       @default(0) @db.Decimal(13, 2)
  isArchived        Boolean       @default(false) @map("is_archived")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  deletedAt         DateTime?     @map("deleted_at")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[] @relation("TransactionAccount")
  transfers         Transaction[] @relation("TransactionTransferAccount")

  @@index([userId, isArchived])
  @@map("accounts")
}

model Category {
  id            String        @id @default(uuid())
  userId        String?       @map("user_id")
  name          String
  kind          CategoryKind
  icon          String?
  isBuiltin     Boolean       @default(false) @map("is_builtin")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  user          User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  budgets       Budget[]

  @@unique([userId, name, kind])
  @@index([userId])
  @@map("categories")
}

model Transaction {
  id                   String                     @id @default(uuid())
  userId               String                     @map("user_id")
  accountId            String                     @map("account_id")
  categoryId           String                     @map("category_id")
  txnDate              DateTime                   @map("txn_date")
  amount               Decimal                    @db.Decimal(13, 2)
  type                 TransactionType
  description          String?
  notes                String?
  isRecurring          Boolean                    @default(false) @map("is_recurring")
  attachmentCount      Int                        @default(0) @map("attachment_count")
  transferAccountId    String?                    @map("transfer_account_id")
  linkedTransactionId  String?                    @unique @map("linked_transaction_id")
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")
  deletedAt            DateTime?                  @map("deleted_at")
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  account              Account                    @relation("TransactionAccount", fields: [accountId], references: [id], onDelete: Restrict)
  category             Category                   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  transferAccount      Account?                   @relation("TransactionTransferAccount", fields: [transferAccountId], references: [id], onDelete: SetNull)
  linkedTransaction    Transaction?               @relation("TransactionLink", fields: [linkedTransactionId], references: [id], onDelete: SetNull)
  mirrorTransaction    Transaction?               @relation("TransactionLink")
  contributions        SavingGoalContribution[]

  @@index([userId, txnDate])
  @@index([accountId, txnDate])
  @@index([categoryId, txnDate])
  @@index([type])
  @@index([transferAccountId])
  @@map("transactions")
}

model Budget {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  categoryId   String       @map("category_id")
  period       BudgetPeriod
  periodStart  DateTime     @map("period_start") @db.Date
  amountLimit  Decimal      @map("amount_limit") @db.Decimal(13, 2)
  carryOver    Boolean      @default(false) @map("carry_over")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, period, periodStart])
  @@index([userId, period, periodStart])
  @@map("budgets")
}

model SavingGoal {
  id             String                    @id @default(uuid())
  userId         String                    @map("user_id")
  name           String
  targetAmount   Decimal                   @map("target_amount") @db.Decimal(13, 2)
  currentAmount  Decimal                   @default(0) @map("current_amount") @db.Decimal(13, 2)
  targetDate     DateTime?                 @map("target_date") @db.Date
  status         SavingGoalStatus          @default(ACTIVE)
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions  SavingGoalContribution[]

  @@index([userId, status])
  @@map("saving_goals")
}

model SavingGoalContribution {
  id             String        @id @default(uuid())
  goalId         String        @map("goal_id")
  userId         String        @map("user_id")
  transactionId  String?       @map("transaction_id")
  amount         Decimal       @db.Decimal(13, 2)
  contributedAt  DateTime      @default(now()) @map("contributed_at")
  goal           SavingGoal    @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction    Transaction?  @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([goalId, contributedAt])
  @@map("saving_goal_contributions")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  type       NotificationType
  message    String
  isRead     Boolean          @default(false) @map("is_read")
  createdAt  DateTime         @default(now()) @map("created_at")
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}
