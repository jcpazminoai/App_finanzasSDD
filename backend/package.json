{
  "name": "app-finanzas-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend NestJS para la app de finanzas personales",
  "scripts": {
    "postinstall": "npm run prisma:generate",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "railway:build": "npm install && npm run build",
    "railway:start": "npm run start:prod",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:integration:db": "node test/scripts/setup-integration-db.js",
    "test:integration": "jest --config test/jest.integration.config.js --runInBand",
    "verify:backend": "npm run build && npm test -- --config test/jest.config.js --runInBand && npm run test:integration:db && npm run test:integration",
    "prisma:generate": "prisma generate --schema ../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema ../prisma/schema.prisma"
  },
  "dependencies": {
    "@as-integrations/express5": "^1.1.2",
    "@apollo/server": "^5.0.0",
    "@nestjs/apollo": "^13.0.4",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/graphql": "^13.0.4",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.9.0",
    "prisma": "^6.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "graphql": "^16.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "jest": "^30.0.2",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}